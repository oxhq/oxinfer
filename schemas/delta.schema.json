{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oxcribe.dev/schema/delta.schema.json",
  "title": "Oxinfer Delta",
  "$defs": {
    "shapeNode": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/shapeNode" }
    },
    "argLiteral": {
      "oneOf": [
        { "type": "string" },
        { "type": "integer" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" }
      ]
    },
    "polymorphicRelation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relation", "type"],
      "properties": {
        "relation": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "enum": ["morphTo", "morphOne", "morphMany", "morphByMany", "morphToMany"] },
        "morphType": { "type": "string", "minLength": 1 },
        "morphId": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "discriminator": {
          "type": "object",
          "additionalProperties": false,
          "required": ["propertyName", "mapping"],
          "properties": {
            "propertyName": { "type": "string", "minLength": 1 },
            "mapping": {
              "type": "object",
              "additionalProperties": { "type": "string", "minLength": 1 }
            },
            "source": { "type": "string", "enum": ["morphMap", "explicit", "inferred"] },
            "isExplicit": { "type": "boolean", "default": false },
            "defaultType": { "type": "string", "minLength": 1 }
          }
        },
        "relatedModels": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "depthTruncated": { "type": "boolean", "default": false },
        "maxDepth": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["meta"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["partial", "stats"],
      "properties": {
        "partial": { "type": "boolean" },
        "stats": {
          "type": "object",
          "additionalProperties": false,
          "required": ["filesParsed", "skipped", "durationMs"],
          "properties": {
            "filesParsed": { "type": "integer", "minimum": 0 },
            "skipped": { "type": "integer", "minimum": 0 },
            "durationMs": { "type": "integer", "minimum": 0 }
          }
        ,
        "version": { "type": "string" },
        "generatedAt": { "type": "string", "format": "date-time" }
        }
      }
    },
    "controllers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["fqcn", "method"],
        "properties": {
          "fqcn": { "type": "string", "minLength": 1 },
          "method": { "type": "string", "minLength": 1 },
          "http": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "status": { "type": "integer", "minimum": 100, "maximum": 599 },
              "explicit": { "type": "boolean", "default": false }
            }
          },
          "request": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "contentTypes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["application/json", "multipart/form-data", "application/x-www-form-urlencoded"]
                },
                "uniqueItems": true
              },
              "body": { "$ref": "#/$defs/shapeNode" },
              "query": { "$ref": "#/$defs/shapeNode" },
              "files": { "$ref": "#/$defs/shapeNode" }
            }
          },
          "resources": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["class", "collection"],
              "properties": {
                "class": { "type": "string", "minLength": 1 },
                "collection": { "type": "boolean" }
              }
            }
          },
          "scopesUsed": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["on", "name"],
              "properties": {
                "on": { "type": "string", "minLength": 1 },
                "name": { "type": "string", "minLength": 1 },
                "args": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/argLiteral" },
                  "default": []
                }
              }
            }
          },
          "polymorphic": {
            "type": "array",
            "items": { "$ref": "#/$defs/polymorphicRelation" },
            "default": []
          }
        }
      },
      "default": []
    },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["fqcn"],
        "properties": {
          "fqcn": { "type": "string", "minLength": 1 },
          "withPivot": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["relation", "columns"],
              "properties": {
                "relation": { "type": "string", "minLength": 1 },
                "columns": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 }
                },
                "alias": { "type": "string", "minLength": 1 },
                "timestamps": { "type": "boolean", "default": false }
              }
            },
            "default": []
          },
          "attributes": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "via"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "via": { "type": "string", "enum": ["Attribute::make"] }
              }
            },
            "default": []
          },
          "polymorphic": {
            "type": "array",
            "items": { "$ref": "#/$defs/polymorphicRelation" },
            "default": []
          }
        }
      },
      "default": []
    },
    "polymorphic": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["parent", "morph", "discriminator"],
        "properties": {
          "parent": { "type": "string", "minLength": 1 },
          "morph": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "typeColumn", "idColumn"],
            "properties": {
              "key": { "type": "string", "minLength": 1 },
              "typeColumn": { "type": "string", "minLength": 1 },
              "idColumn": { "type": "string", "minLength": 1 }
            }
          },
          "discriminator": {
            "type": "object",
            "additionalProperties": false,
            "required": ["propertyName", "mapping"],
            "properties": {
              "propertyName": { "type": "string", "minLength": 1 },
              "mapping": {
                "type": "object",
                "minProperties": 1,
                "additionalProperties": { "type": "string", "minLength": 1 }
              }
            }
          },
          "depthTruncated": { "type": "boolean", "default": false }
        }
      },
      "default": []
    },
    "broadcast": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["channel", "params", "visibility"],
        "properties": {
          "file": { "type": "string" },
          "channel": { "type": "string", "minLength": 1 },
          "params": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "default": []
          },
          "visibility": { "type": "string", "enum": ["public", "private", "presence"] },
          "payloadLiteral": { "type": "boolean", "default": false }
        }
      },
      "default": []
    }
  }
}
