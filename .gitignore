# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
*.prof
*.pprof
coverage.html
cover.out

# Profiling files
cpu.prof
mem.prof

# Build output
/bin/
/dist/
/oxinfer
/bench
/validate-determinism
/validate-mvp

# Go mod cache
/vendor/

# IDE specific files
.vscode/
.idea/
CLAUDE.md
*.swp
*.swo
*~

# OS specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary files
*.tmp
*.temp
*.log

# Test artifacts and fixtures (if large)
/test/fixtures/projects/*
!/test/fixtures/projects/.keep

# Output files from CLI
delta.json
output.json
*.delta.json

# Test output directory
temp_test_outputs/

# Demo files (created for testing)
demo-manifest.json
invalid-manifest.json
composer.json
/app/
/routes/

# Keep these dot files/folders
.*/
!.gitignore
!.go-version
!.github/
!.github/workflows/
!.github/workflows/ci.yml

# Allow tracking .oxinfer/README.md but ignore other .oxinfer contents
!.oxinfer/
!.oxinfer/README.md
.oxinfer/*
!.oxinfer/README.md

# Nested generated analyzer artifacts
**/.oxinfer/
