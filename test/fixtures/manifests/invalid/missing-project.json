{
  "analysis": {
    "patterns": ["**/*.php"],
    "exclude": ["vendor/**"],
    "depth": 10,
    "limits": {
      "max_files": 1000,
      "max_file_size": 1048576
    },
    "features": {
      "routes": true,
      "controllers": true,
      "models": true,
      "middleware": true,
      "migrations": true
    }
  },
  "output": {
    "format": "json",
    "pretty": false
  }
}